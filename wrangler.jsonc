{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "jabsargent-com",
	"compatibility_date": "2026-02-14",
	"compatibility_flags": ["nodejs_als", "nodejs_compat"],
	"pages_build_output_dir": ".svelte-kit/cloudflare",
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "jabsargent-media"
		}
	]
}
